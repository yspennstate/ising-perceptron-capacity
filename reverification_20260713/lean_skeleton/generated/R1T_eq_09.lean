def pathOfString (s : String) : List Bool := s.toList.map (fun c => c == '1')

def coverAux (paths : List (List Bool)) (fuel : Nat) (pre : List Bool) : Bool :=
  if paths.any (fun p => p == pre) then
    paths.all (fun p => p == pre || !(pre.isPrefixOf p))
