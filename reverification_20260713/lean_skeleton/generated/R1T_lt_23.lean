    | 0 => false
    | Nat.succ f => coverAux paths f (pre ++ [false]) && coverAux paths f (pre ++ [true])

/-- Complete, prefix-free, duplicate-free binary leaf cover of depth <= `depth`. -/
def coverOk (paths : List String) (depth : Nat) : Bool :=
