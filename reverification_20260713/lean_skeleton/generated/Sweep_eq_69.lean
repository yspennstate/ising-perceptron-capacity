def allLt (xs : List (Int × Int × Int × Int)) : Bool :=
  xs.all fracLt

def allNeg (xs : List (Int × Int)) : Bool :=
  xs.all negPacket

def allPos (xs : List (Int × Int)) : Bool :=
  xs.all posPacket

