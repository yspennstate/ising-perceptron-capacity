/-- Weak rational order a/b <= c/d with positive denominators. -/
def fracLe : Int × Int × Int × Int → Bool
  | (a, b, c, d) => decide (0 < b) && decide (0 < d) && decide (a * d <= c * b)

def allLe (xs : List (Int × Int × Int × Int)) : Bool :=
