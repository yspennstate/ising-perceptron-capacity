    Claims: interval nonempty, and mid-rad > 0 (resp. mid+rad < 0). -/
def leafOk : Int × Int × Int × Int × Int × Int × Bool → Bool
  | (nLo, dLo, nHi, dHi, mid, rad, s) =>
